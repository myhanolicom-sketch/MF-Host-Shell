# EditorConfig helps maintain consistent coding styles for multiple developers
# working on the same project across various editors and IDEs.
# editorconfig.org

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# JavaScript, TypeScript, JSON, YAML files
[*.{js,ts,json,yaml,yml}]
indent_style = space
indent_size = 2

# HTML files
[*.html]
indent_style = space
indent_size = 2

# SCSS/CSS files
[*.{scss,css}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# Package.json/package-lock.json
[{package.json,package-lock.json}]
indent_style = space
indent_size = 2

# Configuration files
[{.prettierrc,.eslintrc,.angularrc}]
indent_style = space
indent_size = 2
